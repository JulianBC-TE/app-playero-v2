{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "./src/backend/index.ts",
    "./src/dto/index.ts",
    "./src/components/index.ts",
    "./src/hooks/index.ts",
    "./src/contexts/index.ts",
    "./src/screens/index.ts",
    "./src/storage/index.ts",
  ],
  "entryPointStrategy": "expand",
  "out": "docs",
  "name": "Documentación Local DB - Playero",
  "includeVersion": true,
  "exclude": [
    "**/node_modules/**",
    "**/drizzle/**",
    "**/*.js"
  ],
  "cleanOutputDir": true,
  "hideGenerator": true,
  "searchInComments": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "visibilityFilters": {
    "protected": false,
    "private": false,
    "@internal": false
  }
}